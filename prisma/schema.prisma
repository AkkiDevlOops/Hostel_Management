generator client {
provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model Student {
  id String @unique @id @default(cuid())
  name  String
  email String @unique
  Enrollment String @unique
  password String 
  createdAt DateTime @default(now())
}


model attendanceqr{
  id String @unique @id
  name String @default("QR")
  token String 
  createdAt DateTime @default(now())
  expiresAt DateTime 
}

