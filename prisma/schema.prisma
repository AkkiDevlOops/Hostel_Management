generator client {
provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model Student {
  id String @unique @id @default(cuid())
  name  String
  email String 
  Enrollment String @unique
  password String 
  sessions Session[]
  createdAt DateTime @default(now())
}


model attendanceqr{
  id String @unique @id
  name String @default("QR")
  token String 
  createdAt DateTime @default(now())
  expiresAt DateTime 
}

model Garbage{
  id String @unique @id
  Garbage_type String
  Description String
  Location String
  imageUrl String?
  createdAT DateTime @default(now())
}

  model Session{
    id String @id
    studentId String @unique
    student  Student  @relation(fields: [studentId], references: [id]) //not a column a relation
    createdAt DateTime @default(now())
    expiresAt DateTime
  }